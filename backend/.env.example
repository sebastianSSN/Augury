# ── Base de datos ─────────────────────────────────────────────────────────────
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/minisaas

# ── Seguridad ─────────────────────────────────────────────────────────────────
# Genera uno seguro con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-change-in-production

# ── Almacenamiento de modelos ─────────────────────────────────────────────────
# Directorio raíz donde se guardan los modelos por usuario ({MODEL_DIR}/{user_id}/)
# En Render: /app/models  |  En local: dejar vacío usa el directorio actual
MODEL_DIR=./models

# ── CORS ──────────────────────────────────────────────────────────────────────
# Orígenes permitidos (separados por coma, sin espacios)
# En producción: reemplazar con el dominio real del frontend
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
